{
  "name": "@paragraph-com/mcp",
  "version": "1.3.3",
  "type": "module",
  "description": "MCP server for Paragraph — expose your publication to AI agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/paragraph-xyz/paragraph-mcp.git"
  },
  "homepage": "https://github.com/paragraph-xyz/paragraph-mcp#readme",
  "bugs": {
    "url": "https://github.com/paragraph-xyz/paragraph-mcp/issues"
  },
  "license": "MIT",
  "bin": {
    "paragraph-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:worker": "wrangler deploy --dry-run --outdir dist-worker",
    "dev": "tsup --watch",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsup",
    "release": "scripts/release.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@paragraph-com/sdk": "^2.0.2",
    "@whetstone-research/doppler-sdk": "^0.0.1-alpha.62",
    "agents": "^0.8.7",
    "doppler-router": "^1.0.15",
    "hono": "^4.12.9",
    "viem": "^2.40.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1",
    "wrangler": "^4.84.0"
  },
  "packageManager": "yarn@3.4.1"
}
